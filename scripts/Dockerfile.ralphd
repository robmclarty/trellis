# Dockerfile.ralphd — Sandboxed Claude Code environment for ralphd iterations.
#
# Provides a disposable container with Claude Code installed. The project
# directory is bind-mounted at runtime, so no source code is baked into the
# image. --dangerously-skip-permissions is safe here because the container
# is the blast-radius boundary.
#
# Auth: OAuth credentials persist in the named volume `trellis-ralphd-auth`
# mounted at /home/claude/.claude. Run `ralphd-loop.sh --login` once to
# authenticate, then all subsequent iterations reuse the stored session.
#
# Build:  docker build -t trellis-ralphd -f scripts/Dockerfile.ralphd .
# Run:    (managed by scripts/ralphd-loop.sh — not invoked directly)

FROM node:22-slim

# System dependencies for Claude Code and git operations inside the container
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    ca-certificates \
    python3 \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code globally (as root, before user switch)
RUN npm install -g @anthropic-ai/claude-code

# Non-root user — the auth volume mounts at /home/claude/.claude
RUN useradd -m -s /bin/bash claude
USER claude

# Working directory matches the bind-mount target
WORKDIR /workspace

# Default entrypoint — the loop script overrides the command per iteration
ENTRYPOINT ["claude"]
